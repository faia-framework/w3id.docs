#################################################################
#    Data properties
#################################################################

###  https://w3id.org/faia-framework/faia_ont/systemVersion
faia_ont:systemVersion rdf:type owl:DatatypeProperty ;
             rdfs:domain <https://w3id.org/liccium/ont/Declaration> ;
             rdfs:range xsd:string ;
             rdfs:comment "The version field specifies the particular version of the AI system used. Where known, this should follow the naming or numbering scheme provided by the system’s operator." ;
             rdfs:label "system version" .


###  https://w3id.org/faia-framework/faia_ont/activityCode
faia_ont:activityCode rdf:type owl:DatatypeProperty ;
                  rdfs:domain <https://w3id.org/liccium/ont/Declaration> ;
                  rdfs:range xsd:anyURI ;
                  rdfs:comment "Code describing the activity or workflow step, aligned with FAIA or STM AI classification." ;
                  rdfs:label "activity code" .


###  https://w3id.org/faia-framework/faia_ont/faiaFlag
faia_ont:faiaFlag rdf:type owl:DatatypeProperty ;
              rdfs:domain <https://w3id.org/liccium/ont/Declaration> ;
              rdfs:range xsd:anyURI ;
              rdfs:comment "Indicates AI involvement in the creation or modification of the work, according to the FAIA classification." ;
              rdfs:label "FAIA flag" .


###  https://w3id.org/faia-framework/faia_ont/systemAttribution
faia_ont:systemAttribution rdf:type owl:DatatypeProperty ;
                                  rdfs:domain <https://w3id.org/liccium/ont/Declaration> ;
                                  rdfs:range xsd:string ;
                                  rdfs:comment "The system field identifies the AI system or engine used to generate or modify the content. This may include the name of the system or model family, ideally using the provider’s official designation." ;
                                  rdfs:label "system attribution" .


